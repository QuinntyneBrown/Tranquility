@startuml transfer-cancel
' Requirements: L1-FDP-001, L2-FDP-002
' Source: docs/specs/ccsds-file-delivery-protocol/L1.md, docs/specs/ccsds-file-delivery-protocol/L2.md
title Transfer Cancel - POST /api/filetransfer/{instance}/{serviceName}/transfers/{id}:cancel
autonumber

actor "Operator/Client" as OP
participant "HTTP API" as API
participant "CancelTransferHandler" as XTH
participant "CFDP Engine" as ENG
participant "CFDP Transaction" as TXN
participant "PDU Router" as PR
participant "Spacecraft" as SC
database "Transfer Archive" as ARC
database "Audit Log" as AUD

OP -> API ++ : POST .../transfers/{id}:cancel
API -> XTH ++ : CancelTransferCommand(instance, serviceName, transferId)
XTH -> ENG ++ : Cancel(transferId)

alt transfer unknown
    ENG --> XTH : TransferNotFound
    XTH --> API : NotFound
    API --> OP : 404 Not Found
else transfer already COMPLETED or FAILED
    ENG --> XTH : InvalidState(terminal state)
    XTH --> API : Conflict
    API --> OP : 409 Conflict\n{message: "transfer already finished"}
else transfer RUNNING or PAUSED
    ENG -> TXN ++ : Cancel(condition=CANCEL_REQUEST_RECEIVED)
    TXN -> PR : EOF PDU (condition=CANCEL_REQUEST_RECEIVED)
    PR -> SC : uplink EOF (cancel) PDU\nvia data link and ground station
    TXN -> TXN : release file stream,\nstop retransmission timers
    TXN --> ENG -- : state -> CANCELLED
    ENG --> XTH -- : state=CANCELLED
    XTH -> ARC ++ : UpdateTransferRecord(transferId, CANCELLED)
    ARC --> XTH --
    XTH -> AUD ++ : Append(caller, "transfer.cancel", transferId)
    AUD --> XTH --
    XTH --> API -- : TransferInfo(state=CANCELLED)
    API --> OP -- : 200 OK {id, state: "CANCELLED"}
    note right of OP
        L2-FDP-002 AC: GIVEN an active transfer
        WHEN cancel is invoked THEN transfer state
        transitions reflect the requested operation.
    end note
end
@enduml
