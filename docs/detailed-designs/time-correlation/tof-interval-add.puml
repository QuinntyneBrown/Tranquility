@startuml tof-interval-add
' Requirements: L1-TIM-001, L2-TIM-003
' Source: docs/specs/time-correlation/L1.md, docs/specs/time-correlation/L2.md
title Time-of-Flight Interval Add - POST /api/tco/{instance}/{serviceName}/tof:addIntervals
autonumber
actor "Operator/Client" as OP
participant "HTTP API" as API
participant "Authorization Filter" as AUTHZ
participant "AddTofIntervals Command Handler" as CH
participant "Instance Registry" as REG
participant "Time Correlation Service" as TCO
participant "Time-of-Flight Estimator" as TOF

OP -> API ++ : POST /api/tco/{instance}/{serviceName}/tof:addIntervals\n{intervals: [{ertStart, ertStop, polCoef[]}]}
API -> AUTHZ ++ : Authorize(caller, ControlTimeCorrelation)
AUTHZ --> API -- : decision
alt caller lacks ControlTimeCorrelation privilege
    API --> OP : 403 Forbidden {message}
else caller authorized
    API -> CH ++ : AddTofIntervalsCommand(instance, serviceName, intervals)
    CH -> REG ++ : ResolveTcoService(instance, serviceName)
    REG --> CH -- : service handle
    CH -> TCO ++ : ValidateIntervals(intervals)
    TCO --> CH -- : validation result
    alt interval invalid (ertStart >= ertStop, empty polCoef, unparseable times)
        CH --> API : ValidationError(intervalIndex, reason)
        API --> OP : 400 Bad Request {intervalIndex, reason}
    else all intervals valid
        CH -> TCO ++ : AddIntervals(intervals)
        TCO -> TOF ++ : Insert(intervals)
        TOF -> TOF : insert into ordered interval set\n(later additions take precedence on overlap)
        TOF --> TCO -- : interval set updated
        TCO --> CH -- : added
        CH --> API : Ok {addedCount}
        API --> OP : 200 OK {addedCount}
    end
    deactivate CH
end
deactivate API

== Interval set change visible in service state ==
OP -> API ++ : GET /api/tco/{instance}/{serviceName}/status
API --> OP -- : 200 OK {state includes added time-of-flight intervals}
note right of OP
    AC L2-TIM-003: GIVEN an interval add request
    WHEN method executes THEN interval set changes
    are visible in time-correlation service state.
end note
@enduml
