@startuml mdb-parameter-resolution
' Requirements: L2-MDB-003, L1-MDB-001
' Source: docs/specs/mission-database/L1.md, docs/specs/mission-database/L2.md
title MDB API: Parameter Resolution by Qualified Name and Alias
autonumber

actor "Operator Client" as OP
participant "HTTP API" as API
participant "GetParameterHandler" as QH
participant "Instance Registry" as REG
participant "Name Index" as IDX
participant "MDB Model" as MODEL

== Resolution by qualified name ==
OP -> API ++ : GET /api/mdb/{instance}/parameters\n/SC1/EPS/BatteryVoltage
API -> QH ++ : GetParameterQuery(instance,\nqualifiedName)
QH -> REG ++ : GetActiveModel(instance)
REG --> QH -- : MdbModel reference
QH -> IDX ++ : ResolveQualified(\n"/SC1/EPS/BatteryVoltage")
IDX --> QH -- : parameterId = P-1042
QH -> MODEL ++ : GetParameterInfo(P-1042)
MODEL --> QH -- : ParameterInfo(type, units,\naliases, containerRefs)
QH --> API -- : ParameterInfo
API --> OP -- : 200 OK {qualifiedName,\nalias set, type}

== Resolution by alias ==
OP -> API ++ : GET /api/mdb/{instance}/parameters\n/alias/MIL-STD/BATT_V
API -> QH ++ : GetParameterQuery(instance,\nnamespace="MIL-STD",\nalias="BATT_V")
QH -> REG ++ : GetActiveModel(instance)
REG --> QH -- : MdbModel reference
QH -> IDX ++ : ResolveAlias("MIL-STD", "BATT_V")

alt Alias defined in XTCE alias namespace
    IDX --> QH : parameterId = P-1042
    QH -> MODEL ++ : GetParameterInfo(P-1042)
    MODEL --> QH -- : ParameterInfo (same entry)
    QH --> API : ParameterInfo
    API --> OP : 200 OK (identical parameter)
    note over IDX, MODEL
      L2-MDB-003: GIVEN a parameter alias mapping
      WHEN a client uses alias-based identification
      THEN the same parameter (P-1042) is resolved
      as with the qualified name
    end note
else Name or alias not found in index
    IDX --> QH -- : no match
    QH --> API -- : NotFound(name, namespace)
    API --> OP -- : 404 Not Found\n{error: "parameter not defined\nin active mission database"}
end
@enduml
